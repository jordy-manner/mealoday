// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Recipe {
  id          String   @id @default(cuid())
  title       String
  description String?
  servings    Int?
  prepTime    Int? // minutes
  cookTime    Int? // minutes
  steps       Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Ingredients of the recipe (many-to-many via the explicit RecipeIngredient
  // join, which carries the quantity and the unit).
  recipeIngredients RecipeIngredient[]
  // Utensils of the recipe (many-to-many via the explicit RecipeUtensil join,
  // which carries the quantity).
  recipeUtensils    RecipeUtensil[]
  // Shared tags (many-to-many via the explicit RecipeTag join table).
  recipeTags        RecipeTag[]
}

// Catalog of reusable ingredients (e.g. "farine", "œuf"). Unique name.
model Ingredient {
  id                String             @id @default(cuid())
  name              String             @unique
  recipeIngredients RecipeIngredient[]
}

// Catalog of reusable units of measure (e.g. "g", "kg", "ml", "pincée", "unité").
model Unit {
  id                String             @id @default(cuid())
  name              String             @unique
  recipeIngredients RecipeIngredient[]
}

// Explicit Recipe <-> Ingredient join, carrying the quantity and the unit.
// Table "RecipeIngredient" (columns recipeId / ingredientId, composite PK).
model RecipeIngredient {
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId     String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  ingredientId String
  quantity     Float? // e.g. 250, 0.5, 3 — optional ("sel à volonté")
  unit         Unit?      @relation(fields: [unitId], references: [id], onDelete: SetNull)
  unitId       String?
  position     Int        @default(0) // display order within the recipe

  @@id([recipeId, ingredientId])
  @@index([ingredientId])
  @@index([unitId])
}

// Catalog of reusable utensils (e.g. "cuillère en bois", "moule à manqué
// 24 cm", "poêle 28 cm"). Unique name. Size variants (diameter) are distinct
// catalog entries.
model Utensil {
  id             String          @id @default(cuid())
  name           String          @unique
  recipeUtensils RecipeUtensil[]
}

// Explicit Recipe <-> Utensil join, carrying the quantity (number of utensils).
// Table "RecipeUtensil" (columns recipeId / utensilId, composite PK).
model RecipeUtensil {
  recipe    Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId  String
  utensil   Utensil @relation(fields: [utensilId], references: [id], onDelete: Cascade)
  utensilId String
  quantity  Int? // e.g. 1, 2 — optional (defaults to 1 when displayed)
  position  Int     @default(0) // display order within the recipe

  @@id([recipeId, utensilId])
  @@index([utensilId])
}

// A tag is reusable and shared across multiple recipes.
model Tag {
  id         String      @id @default(cuid())
  name       String      @unique
  recipeTags RecipeTag[]
}

// Explicit join table for the many-to-many Recipe <-> Tag relation.
// Table: "RecipeTag", columns: "recipeId" and "tagId" (composite primary key).
model RecipeTag {
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId    String

  @@id([recipeId, tagId])
  @@index([tagId])
}
