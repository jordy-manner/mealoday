# =============================================================================
# Template des variables d'environnement (COMMITÉ dans le dépôt)
# -----------------------------------------------------------------------------
# Ce fichier ne sert que de nomenclature : il liste les variables attendues,
# SANS valeurs sensibles. Les vraies valeurs (identifiants, secrets) vont dans
# .env.local, qui est ignoré par git.
#
# Ordre de chargement Next.js : .env  ->  .env.local (surcharge).
# Côté Prisma CLI, .env.local est chargé via prisma.config.ts.
# =============================================================================

# URL de connexion PostgreSQL (Neon). Valeur réelle à placer dans .env.local :
# postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# Version de l'app = tag git courant. Non secret, commité ici.
# Mis à jour automatiquement en préambule de chaque preview-release
# (cf. skill preview-release) vers le tag sur le point d'être créé.
APP_RELEASE=v0.1.8

# Mode maintenance (proxy.ts). "true" => le site renvoie une 503 « En construction ».
# À activer UNIQUEMENT sur la Production Vercel (off en Preview/local).
# Toggler cette valeur nécessite un redeploy Vercel.
APP_MAINTENANCE=

# Secret de bypass du mode maintenance : visiter ...?unlock=<secret> pose un cookie
# qui laisse voir le vrai site malgré la maintenance. Valeur réelle dans .env.local /
# env Vercel (Production), jamais commitée.
APP_MAINTENANCE_BYPASS=
